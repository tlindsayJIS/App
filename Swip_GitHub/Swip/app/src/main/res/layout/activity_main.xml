<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#080B14"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="32dp">

        <!-- Logo row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="6dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Swip"
                android:textColor="#FFFFFF"
                android:textSize="32sp"
                android:textStyle="bold"
                android:letterSpacing="-0.02" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="v1.0"
                android:textColor="#3B5AFE"
                android:textSize="12sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:background="@drawable/pill_blue" />
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Starting..."
            android:textColor="#00E676"
            android:textSize="13sp"
            android:layout_marginBottom="28dp" />

        <!-- Accessibility setup card (hidden when enabled) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardAccessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardBackgroundColor="#0F2010"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Enable Skip Detection"
                        android:textColor="#AAFFAA"
                        android:textSize="14sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="One-time setup to detect YouTube ads"
                        android:textColor="#558855"
                        android:textSize="12sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Setup"
                    android:textColor="#00E676"
                    android:textSize="13sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SKIP AD button (shown only when ad detected) -->
        <Button
            android:id="@+id/btnSkip"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginBottom="14dp"
            android:text="SKIP AD"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#C62828"
            android:visibility="gone" />

        <!-- VOICE COMMAND button -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_surface"
            android:padding="6dp"
            android:layout_marginBottom="14dp">

            <View
                android:id="@+id/voicePulse"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:background="#EF4444"
                android:visibility="gone"
                android:layout_marginBottom="4dp" />

            <Button
                android:id="@+id/btnVoice"
                android:layout_width="match_parent"
                android:layout_height="88dp"
                android:text="Voice Command"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#7C3AED" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="skip  \u2022  play  \u2022  pause  \u2022  next  \u2022  search"
                android:textColor="#4B5563"
                android:textSize="12sp"
                android:gravity="center"
                android:padding="8dp" />
        </LinearLayout>

        <!-- Wave gesture hint -->
        <TextView
            android:id="@+id/tvWaveHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp"
            android:gravity="center"
            android:text="Wave once = Play/Pause"
            android:textColor="#1E3A5F"
            android:textSize="12sp"
            android:background="@drawable/card_dark_border"
            android:layout_marginBottom="14dp" />

        <!-- YouTube + Driving row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="14dp">

            <Button
                android:id="@+id/btnYoutube"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:layout_marginEnd="10dp"
                android:text="Open YouTube"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#EF4444" />

            <Button
                android:id="@+id/btnDrive"
                android:layout_width="0dp"
                android:layout_height="72dp"
                android:layout_weight="1"
                android:text="Driving Mode"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:backgroundTint="#3D5AFE" />
        </LinearLayout>

        <!-- Command reference -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="#0F1420"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Commands"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.05"
                    android:layout_marginBottom="14dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="skip" android:textColor="#7C3AED"
                            android:textSize="13sp" android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="play" android:textColor="#4B5563"
                            android:textSize="13sp" android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="pause" android:textColor="#4B5563"
                            android:textSize="13sp" android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="next" android:textColor="#4B5563"
                            android:textSize="13sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="volume up" android:textColor="#4B5563"
                            android:textSize="13sp" android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="volume down" android:textColor="#4B5563"
                            android:textSize="13sp" android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="search music" android:textColor="#4B5563"
                            android:textSize="13sp" android:layout_marginBottom="10dp" />
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="open youtube" android:textColor="#4B5563"
                            android:textSize="13sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Safety note -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Keep eyes on the road at all times"
            android:textColor="#1F2937"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="20dp" />

    </LinearLayout>
</ScrollView>
